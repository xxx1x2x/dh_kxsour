        _G.rb_isInCombat=false; _G.rb_shouldSwitch=true; lockedTarget=nil
        _G.rb_smoothedTargetPos=nil; _G.rb_voiding=true; _G.rb_teleporting=false; reloadTool()
        return
    end
    if TargetFF then
        messageLabel.Text="waiting FF... (void)"
        _G.rb_isInCombat=false; _G.rb_voiding=true; _G.rb_teleporting=false; reloadTool()
        if ragebotviewactive then
            workspace.CurrentCamera.CameraSubject = UpperTorso or TargetHum
        else
            workspace.CurrentCamera.CameraSubject = Character:FindFirstChild("Humanoid")
        end
        return
    end
    _G.rb_isInCombat=true; _G.rb_voiding=false; _G.rb_teleporting=true
    if ragebotviewactive then workspace.CurrentCamera.CameraSubject=UpperTorso or TargetHum
    else workspace.CurrentCamera.CameraSubject=Character:FindFirstChild("Humanoid") end

    if isKO and UpperTorso and ragebotstompactive and _G.rb_canrun then
        messageLabel.Text="stomping: "..lockedTarget.Name
        _G.rb_teleporting=false
        _G.rb_voiding=false
        RootPart.Velocity = Vector3.zero
        RootPart.RotVelocity = Vector3.zero
        RootPart.AssemblyLinearVelocity = Vector3.zero
        RootPart.AssemblyAngularVelocity = Vector3.zero
        RootPart.CFrame = CFrame.new(UpperTorso.Position + Vector3.new(0, 3.5, 0))
        task.wait(0.1)
