                    local tHRP = plr.Character:FindFirstChild("HumanoidRootPart")
                    local tHum = plr.Character:FindFirstChild("Humanoid")
                    local be   = plr.Character:FindFirstChild("BodyEffects")
                    local gra  = plr.Character:FindFirstChild("GRABBING_CONSTRAINT")
                    if tHRP and tHum and tHum.Health>0 and be and not gra then
                        local isKO = be:FindFirstChild("K.O") and be["K.O"].Value
                        local sd   = be:FindFirstChild("SDeath") and be["SDeath"].Value
                        if not sd then
                            local dist = (tHRP.Position - RootPart.Position).Magnitude
                            local eff  = isKO and (dist+10000) or dist
                            if eff < closestDist then closestDist=eff lockedTarget=plr end
                        end
                    end
                end
            end
        end
    end
    if not lockedTarget or not lockedTarget.Character then
        if lockedTarget and not lockedTarget:IsDescendantOf(game) then
            _G.rb_lockedTargetUserId = nil
            lockedTarget = nil
