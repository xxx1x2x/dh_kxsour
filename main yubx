local CurrentDanceTrack, CurrentDanceName, DanceSpeed = nil, nil, 1
local function stopDance()
    if CurrentDanceTrack then
        pcall(function() CurrentDanceTrack:Stop() CurrentDanceTrack:Destroy() end)
        CurrentDanceTrack, CurrentDanceName = nil, nil
    end
end
local function playDance(name)
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    stopDance()
    local id = DanceIds[name]
    if not id then return end
    local anim = Instance.new("Animation"); anim.AnimationId = id
    local track = hum:LoadAnimation(anim)
    track.Looped = true
    track:AdjustSpeed(DanceSpeed)
    track:Play()
    CurrentDanceTrack, CurrentDanceName = track, name
end
