        end
        messageLabel.Text="no target... (void)"
        _G.rb_isInCombat=false
        _G.rb_voiding=true; _G.rb_teleporting=false
        reloadTool()
        workspace.CurrentCamera.CameraSubject=Character:FindFirstChild("Humanoid")
        return
    end
    if lockedTarget then _G.rb_lockedTargetUserId = lockedTarget.UserId end
    local TargetChar  = lockedTarget.Character
