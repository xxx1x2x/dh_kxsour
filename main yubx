local function _findArmorShopItem()
    local ignored = _armorWorkspace:FindFirstChild("Ignored")
    if not ignored then return nil end
    local shop = ignored:FindFirstChild("Shop")
    if not shop then return nil end
    for _, item in pairs(shop:GetChildren()) do
        local n = item.Name:lower()
        if n:find("high%-medium armor") or n:find("high-medium armor") then
            return item
        end
    end
    return nil
end

local function _canBuyArmor()
    local character = _armorPlayer.Character
    if not character then return false end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    local bodyEffects = character:FindFirstChild("BodyEffects")
    local isKO = bodyEffects and bodyEffects:FindFirstChild("K.O") and bodyEffects["K.O"].Value
    if isKO then return false end
    return true
end

local function _teleportAndBuy(shopItem)
    local character = _armorPlayer.Character
    if not character then
        getgenv().autoArmorBuying = false
        return
    end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        getgenv().autoArmorBuying = false
        return
    end

    local targetPart = shopItem:FindFirstChild("Head")
    if not targetPart then
        for _, v in pairs(shopItem:GetDescendants()) do
            if v:IsA("BasePart") then targetPart = v break end
        end
    end

    local clickDetector = shopItem:FindFirstChildOfClass("ClickDetector")
    if not clickDetector then
        for _, v in pairs(shopItem:GetDescendants()) do
            if v:IsA("ClickDetector") then clickDetector = v break end
        end
    end

    if not targetPart or not clickDetector then
        getgenv().autoArmorBuying = false
        return
    end

    local originalCFrame = hrp.CFrame
    hrp.CFrame = targetPart.CFrame * CFrame.new(0, 3.1, 0)
    task.wait(0.15)
    fireclickdetector(clickDetector)
    task.wait(0.15)
    hrp.CFrame = originalCFrame

    task.wait(0.5)
    getgenv().autoArmorBuying = false
end

