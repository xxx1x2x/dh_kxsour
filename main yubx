local antiBagEnabled = false
local antiBagCooldown = false
local function doAntiBag(char)
    if antiBagCooldown then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    antiBagCooldown = true
    local saved = hrp.CFrame
    hrp.CFrame = CFrame.new(saved.Position + Vector3.new(0,9999,0))
    task.wait(5)
    for _, v in ipairs(char:GetDescendants()) do
        if v.Name == "Christmas_Sock" then pcall(function() v:Destroy() end) end
    end
    hrp.CFrame = saved
    task.wait(2)
    antiBagCooldown = false
end
local function setupAntiBag(char)
    char.DescendantAdded:Connect(function(desc)
        if not antiBagEnabled then return end
        if desc.Name == "Christmas_Sock" then task.wait(0.05) doAntiBag(char) end
    end)
end
