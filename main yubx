local function scanShop()
    local ignored = workspace:FindFirstChild("Ignored")
    if not ignored then return {} end
    local shop = ignored:FindFirstChild("Shop")
    if not shop then return {} end
    for _, item in ipairs(shop:GetChildren()) do
        local name = string.match(item.Name, "%b[]")
        local head = item:FindFirstChild("Head")
        if head and head.CFrame.p.Y > -35 and name then
            name = name:sub(2,-2)
            if name:find("Ammo") then
                local base = name:sub(1,-6)
                if not all_items[base] then all_items[base]={main=nil,ammo=head}
                elseif not all_items[base].ammo then all_items[base].ammo=head end
            else
                if not all_items[name] then all_items[name]={main=head,ammo=nil}
                elseif not all_items[name].main then all_items[name].main=head end
            end
        end
    end
    local list = {}
    for n, d in pairs(all_items) do if d.ammo then table.insert(list, n) end end
    table.sort(list)
    return list
end

