    enabled=false, refreshrate=0.015, mode='mouse',
    width=2.5, length=10, radius=11, color=Color3.fromRGB(255,255,255),
    spin=true, spin_speed=150, spin_max=340, spin_style=Enum.EasingStyle.Circular,
    resize=true, resize_speed=150, resize_min=5, resize_max=22,
}
local crosshair_last_render = 0
local crosshair_drawings = {lines={}}
for i = 1, 4 do
    crosshair_drawings.lines[i] = Drawing.new('Line')
end
local function crosshair_solve(angle, radius)
    return Vector2.new(math.sin(math.rad(angle))*radius, math.cos(math.rad(angle))*radius)
end
RunService.PostSimulation:Connect(function()
    local _tick = tick()
    if _tick - crosshair_last_render <= getgenv().crosshair.refreshrate then return end
    crosshair_last_render = _tick
    local ch = getgenv().crosshair
    local position = ch.mode=='center' and Camera.ViewportSize/2 or UserInputService:GetMouseLocation()
    if ch.enabled then
        for idx = 1, 4 do
            local line = crosshair_drawings.lines[idx]
            local angle = (idx-1)*90
            local length = ch.length
            if ch.spin then
                local sa = -_tick*ch.spin_speed % ch.spin_max
                angle = angle + TweenService:GetValue(sa/360, ch.spin_style, Enum.EasingDirection.InOut)*360
            end
            if ch.resize then
                local rl = _tick*ch.resize_speed % 180
                length = ch.resize_min + math.sin(math.rad(rl))*ch.resize_max
            end
            line.Visible=true
            line.Color=ch.color
            line.From=position+crosshair_solve(angle,ch.radius)
            line.To  =position+crosshair_solve(angle,ch.radius+length)
            line.Thickness=ch.width
        end
    else
        for i = 1, 4 do crosshair_drawings.lines[i].Visible=false end
    end
end)
