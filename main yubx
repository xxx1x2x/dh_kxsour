local antiConnections = {}
local function stripAnimations(character)
    if character:GetAttribute('AntiServerLaggerHandled') then return end
    character:SetAttribute('AntiServerLaggerHandled', true)
    local hum = character:WaitForChild('Humanoid', 5)
    if not hum then return end
    local anim = hum:FindFirstChildOfClass('Animator')
    if anim then anim:Destroy() end
    local animate = character:FindFirstChild('Animate')
    if animate then animate.Disabled = true end
    for _, v in ipairs(character:GetDescendants()) do
        if v:IsA("BodyVelocity") or v:IsA("BodyGyro") or v:IsA("BodyPosition") or v:IsA("BodyAngularVelocity") or v:IsA("BodyForce") then
            pcall(function() v:Destroy() end)
        end
    end
    character.DescendantAdded:Connect(function(desc)
        if desc:IsA("BodyVelocity") or desc:IsA("BodyGyro") or desc:IsA("BodyPosition") or desc:IsA("BodyAngularVelocity") or desc:IsA("BodyForce") then
            task.defer(function() pcall(function() desc:Destroy() end) end)
        end
    end)
end
local function onRagebotPlayer(player)
    if player==LocalPlayer then return end
    if player.Character then stripAnimations(player.Character) end
    table.insert(antiConnections, player.CharacterAdded:Connect(stripAnimations))
end
local function EnableAntiServerLagger()
    for _, p in ipairs(Players:GetPlayers()) do onRagebotPlayer(p) end
    antiConnections.playerAdded = Players.PlayerAdded:Connect(onRagebotPlayer)
end
local function DisableAntiServerLagger()
    for _, c in pairs(antiConnections) do if typeof(c)=='RBXScriptConnection' then c:Disconnect() end end
    table.clear(antiConnections)
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then p.Character:SetAttribute('AntiServerLaggerHandled',nil) end
    end
end
RespawnAbuseGroupBox:AddToggle('AntiLagger',{Text='Anti Lagger',Default=false,
