local DamageGroup  = Tabs.World:AddLeftGroupbox('Damage Numbers')
local isDmgEnabled = false
local dmgColor     = Color3.fromRGB(255,255,255)
local prevDmgHealth= {}
local dmgRayParams = RaycastParams.new()
dmgRayParams.FilterType  = Enum.RaycastFilterType.Blacklist
dmgRayParams.IgnoreWater = true

local function isVisible(player)
    if not player.Character or not player.Character:FindFirstChild("Head") then return false end
    local head = player.Character.Head
    local orig = Camera.CFrame.Position
    local dir  = (head.Position - orig)
    dmgRayParams.FilterDescendantsInstances = {LocalPlayer.Character}
    local res = workspace:Raycast(orig, dir, dmgRayParams)
    return not res or res.Instance:IsDescendantOf(player.Character)
end

local function getNearestCursor()
    local mouse = UserInputService:GetMouseLocation()
    local nearest, shortest = nil, math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") and isVisible(player) then
            local sp, on = Camera:WorldToViewportPoint(player.Character.Head.Position)
            if on then
                local d = (Vector2.new(sp.X,sp.Y) - mouse).Magnitude
                if d < shortest then shortest=d nearest=player end
            end
        end
    end
    return nearest
end

local function showDamage(player, amount)
    if not isDmgEnabled then return end
    local head = player.Character and player.Character:FindFirstChild("Head")
    if not head then return end
    local gui = head:FindFirstChild("DamageContainer")
    if not gui then
        gui = Instance.new("BillboardGui")
        gui.Name="DamageContainer" gui.Parent=head gui.Adornee=head
        gui.Size=UDim2.new(0,100,0,50) gui.StudsOffset=Vector3.new(0,2,0)
        gui.AlwaysOnTop=true gui.MaxDistance=500 gui.Enabled=true
    end
    local lbl = Instance.new("TextLabel", gui)
    lbl.Text=tostring(amount) lbl.TextColor3=dmgColor
    lbl.TextSize=32+(amount/10) lbl.Font=Enum.Font.SourceSansBold
    lbl.BackgroundTransparency=1 lbl.Size=UDim2.new(1,0,0,32)
    lbl.TextStrokeTransparency=0.4
    lbl.Position=UDim2.new(0.5,-50+math.random(-20,20),0,math.random(-20,20))
    local t1 = TweenService:Create(lbl,TweenInfo.new(3,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Position=UDim2.new(0.5,-50,0,-100)})
    t1:Play()
    t1.Completed:Connect(function()
        local t2 = TweenService:Create(lbl,TweenInfo.new(1,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{TextTransparency=1,TextStrokeTransparency=1})
        t2:Play()
        t2.Completed:Connect(function() lbl:Destroy() end)
    end)
end

RunService.RenderStepped:Connect(function()
