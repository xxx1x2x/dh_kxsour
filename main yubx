local BulletTPSettings = {Enabled=false}
local BulletTPTarget = nil

local function btp_get_closest_target()
    local mouse = LocalPlayer:GetMouse()
    local closest, min_dist = nil, math.huge
    local mouse_pos = mouse.Hit.Position
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = player.Character:FindFirstChild("Humanoid")
            if root and humanoid and humanoid.Health > 0 then
                local dist = (root.Position - mouse_pos).Magnitude
                if dist < min_dist then
                    min_dist = dist
                    closest = player
                end
            end
        end
    end
    BulletTPTarget = closest
end

UserInputService.InputBegan:Connect(function(input, gp)
    if not gp and input.KeyCode == Enum.KeyCode.C and BulletTPSettings.Enabled then
        btp_get_closest_target()
    end
end)

local function btp_cframe_to_offset(origin, target)
    local actual_origin = origin * CFrame.new(0, -1, 0, 1, 0, 0, 0, 0, 1, 0, -1, 0)
    return actual_origin:ToObjectSpace(target)
end

local function btp_teleport_bullet(tool)
    local target = BulletTPTarget
    if not (target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")) then return end
    local origin_part = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local target_part = target.Character.HumanoidRootPart
    if not (origin_part and target_part) then return end

    local original_grip = tool.Grip
    local offset = btp_cframe_to_offset(
        LocalPlayer.Character.RightHand.CFrame,
        target_part.CFrame
    )

    tool.Parent = LocalPlayer.Backpack
    tool.Grip = offset
    tool.Parent = LocalPlayer.Character
    RunService.RenderStepped:Wait()
    tool.Parent = LocalPlayer.Backpack
    tool.Grip = original_grip
    tool.Parent = LocalPlayer.Character
end

local btp_connections = {}

local function btp_handle_character(character)
    for _, conn in ipairs({"btp_child_added", "btp_child_removed"}) do
        if btp_connections[conn] then btp_connections[conn]:Disconnect() end
    end
    btp_connections.btp_child_added = character.ChildAdded:Connect(function(tool)
        if tool:IsA("Tool") then
            pcall(function()
                for _, conn in ipairs(getconnections(tool:GetPropertyChangedSignal("Grip"))) do
                    conn:Disable()
                end
            end)
            btp_connections.btp_tool_activated = tool.Activated:Connect(function()
                if BulletTPSettings.Enabled then
                    btp_teleport_bullet(tool)
                end
            end)
        end
    end)
    btp_connections.btp_child_removed = character.ChildRemoved:Connect(function()
        if btp_connections.btp_tool_activated then
            btp_connections.btp_tool_activated:Disconnect()
        end
    end)
end

local function btp_setup(char)
    btp_handle_character(char)
end

