local function saveDeathPos(char)
    if not respawnEnabled then return end
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then lastDeathPos = hrp.CFrame end
end

local function watchKO(char)
    local be = char:WaitForChild("BodyEffects", 5)
    if not be then return end
    local ko = be:WaitForChild("K.O", 5)
    if not ko then return end

    ko:GetPropertyChangedSignal("Value"):Connect(function()
        if ko.Value then saveDeathPos(char) end
    end)

    local hum = char:FindFirstChild("Humanoid")
    if hum then
        hum:GetPropertyChangedSignal("Health"):Connect(function()
            if hum.Health <= 0 then saveDeathPos(char) end
        end)
    end
end

