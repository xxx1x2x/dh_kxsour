    if isKO and ragebotNotificationsEnabled and lastKilledTarget~=lockedTarget.UserId then
        killCount=killCount+1; lastKilledTarget=lockedTarget.UserId
        Library:Notify(string.format("✦ KILL  %s  [%d / %d]", lockedTarget.Name, killCount, deathCount), 4)
    end
