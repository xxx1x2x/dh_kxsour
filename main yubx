                    * CFrame.Angles(math.rad(math.random(0,360)), math.rad(math.random(0,360)), math.rad(math.random(0,360)))
            else
                RootPart.CFrame = CFrame.lookAt(tPos + Vector3.new(math.random(-20,20), math.random(-20,20), math.random(-20,20)), tPos)
            end
        else
            RootPart.CFrame = CFrame.lookAt(
                tPos + Vector3.new(math.random(-20, 20), math.random(-20, 20), math.random(-20, 20)),
                tPos
