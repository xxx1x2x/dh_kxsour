            if head then
                found = true
                local p = head.Position
                local hs = 0.5
                minX=math.min(minX,p.X-hs) minY=math.min(minY,p.Y-hs) minZ=math.min(minZ,p.Z-hs)
                maxX=math.max(maxX,p.X+hs) maxY=math.max(maxY,p.Y+hs) maxZ=math.max(maxZ,p.Z+hs)
            end
            if not found then return nil end
            return Vector3.new(minX,minY,minZ), Vector3.new(maxX,maxY,maxZ)
        end
        local function w2s(pos)
            local sp, on = cam:WorldToViewportPoint(pos)
            return Vector2.new(sp.X,sp.Y), on, sp.Z
        end
        local function createPlayerESP(player)
            if playerESP[player] then return end
            local d = {
                box = {
                    top=newLine(1,boxColor,3), bottom=newLine(1,boxColor,3),
                    left=newLine(1,boxColor,3), right=newLine(1,boxColor,3),
                    fill=newQuad(boxFillColor,true,1-boxFillTransparency,1),
                },
                healthBar = {bg=newLine(4,Color3.new(0,0,0),2), bar=newLine(2,Color3.fromRGB(0,255,0),3)},
                armorBar  = {bg=newLine(4,Color3.new(0,0,0),2), bar=newLine(2,armorBarColor,3)},
                name=newText(13,namesColor,4), distance=newText(11,distanceColor,4),
                tool=newText(11,toolColor,4), tracer=newLine(1,tracerColor,1),
                skeleton={}, highlight=nil, chams={},
            }
            for i=1,#skeletonBones do d.skeleton[i]=newLine(1,skeletonColor,2) end
            playerESP[player] = d
        end
        local function removePlayerESP(player)
            local d = playerESP[player]
            if not d then return end
            for _,v in pairs(d.box) do pcall(function() if v.Remove then v:Remove() else v:Destroy() end end) end
            for _,v in pairs(d.healthBar) do pcall(function() v:Remove() end) end
            for _,v in pairs(d.armorBar)  do pcall(function() v:Remove() end) end
            pcall(function() d.name:Remove() end) pcall(function() d.distance:Remove() end)
            pcall(function() d.tool:Remove() end) pcall(function() d.tracer:Remove() end)
            for _,l in ipairs(d.skeleton) do pcall(function() l:Remove() end) end
            if d.highlight and d.highlight.Parent then d.highlight:Destroy() end
            for _,inst in ipairs(d.chams) do if inst.Parent then inst:Destroy() end end
            playerESP[player] = nil
        end
        local function updateHighlight(player, d)
            if not player.Character then
                if d.highlight and d.highlight.Parent then d.highlight:Destroy() d.highlight=nil end
                return
            end
            if highlightEnabled then
                if not d.highlight or not d.highlight.Parent then
                    local hl = Instance.new('Highlight')
                    hl.FillColor=highlightFillColor hl.OutlineColor=highlightOutlineColor
                    hl.FillTransparency=highlightFillTransparency hl.OutlineTransparency=highlightOutlineTransparency
                    hl.Adornee=player.Character hl.Parent=espFolder
                    d.highlight=hl
                else
                    d.highlight.FillColor=highlightFillColor d.highlight.OutlineColor=highlightOutlineColor
                    d.highlight.FillTransparency=highlightFillTransparency d.highlight.OutlineTransparency=highlightOutlineTransparency
                end
            else
                if d.highlight and d.highlight.Parent then d.highlight:Destroy() d.highlight=nil end
            end
        end
        local function updateChams(player, d)
            if not player.Character then
                for _,inst in ipairs(d.chams) do if inst.Parent then inst:Destroy() end end
                d.chams={} return
            end
            if chamsEnabled then
                if #d.chams==0 then
                    for _,part in ipairs(player.Character:GetChildren()) do
                        if part:IsA('BasePart') then
                            local box = Instance.new('BoxHandleAdornment')
                            box.Size=part.Size+Vector3.new(0.05,0.05,0.05)
                            box.Color3=chamsColor box.AlwaysOnTop=true
                            box.ZIndex=1 box.Transparency=chamsTransparency
                            box.Adornee=part box.Parent=espFolder
                            table.insert(d.chams,box)
                        end
                    end
                else
                    for _,box in ipairs(d.chams) do box.Color3=chamsColor box.Transparency=chamsTransparency end
                end
            else
                for _,inst in ipairs(d.chams) do if inst.Parent then inst:Destroy() end end
                d.chams={}
            end
        end
        local function hideAll(d)
            for _,v in pairs(d.box) do v.Visible=false end
            d.healthBar.bg.Visible=false d.healthBar.bar.Visible=false
            d.armorBar.bg.Visible=false  d.armorBar.bar.Visible=false
            d.name.Visible=false d.distance.Visible=false d.tool.Visible=false d.tracer.Visible=false
            for _,l in ipairs(d.skeleton) do l.Visible=false end
        end
        local function updatePlayer(player, d)
            local char = player.Character
            if not char then hideAll(d) return end
            local hrp = char:FindFirstChild('HumanoidRootPart')
            local hum = char:FindFirstChild('Humanoid')
            if not hrp or not hum or hum.Health<=0 then hideAll(d) return end
            local minB,maxB = getCharacterBounds(char)
            if not minB then hideAll(d) return end
            local topCenter = Vector3.new((minB.X+maxB.X)/2,maxB.Y,(minB.Z+maxB.Z)/2)
            local botCenter = Vector3.new((minB.X+maxB.X)/2,minB.Y,(minB.Z+maxB.Z)/2)
            local sTop,onTop,dTop = w2s(topCenter)
            local sBot,onBot      = w2s(botCenter)
            if (not onTop and not onBot) or dTop<0 then hideAll(d) return end
            local height = math.abs(sTop.Y-sBot.Y)
            local width  = height*0.6
            local left,right,top,bottom = sTop.X-width/2,sTop.X+width/2,sTop.Y,sBot.Y
            local dist = math.floor((hrp.Position-cam.CFrame.Position).Magnitude)
            if boxEnabled and enabled then
                d.box.top.From=Vector2.new(left,top)       d.box.top.To=Vector2.new(right,top)
                d.box.bottom.From=Vector2.new(left,bottom) d.box.bottom.To=Vector2.new(right,bottom)
                d.box.left.From=Vector2.new(left,top)      d.box.left.To=Vector2.new(left,bottom)
                d.box.right.From=Vector2.new(right,top)    d.box.right.To=Vector2.new(right,bottom)
                for _,b in pairs({d.box.top,d.box.bottom,d.box.left,d.box.right}) do
                    b.Color=boxColor b.Transparency=1 b.Visible=true
                end
                if boxFill then
                    d.box.fill.PointA=Vector2.new(left,top)   d.box.fill.PointB=Vector2.new(right,top)
                    d.box.fill.PointC=Vector2.new(right,bottom) d.box.fill.PointD=Vector2.new(left,bottom)
                    d.box.fill.Color=boxFillColor d.box.fill.Transparency=boxFillTransparency d.box.fill.Visible=true
                else d.box.fill.Visible=false end
            else for _,b in pairs(d.box) do b.Visible=false end end
            if healthBarEnabled and enabled then
                local ratio = math.clamp(hum.Health/hum.MaxHealth,0,1)
                local barH = height*ratio
                local barX = healthBarSide=='Left' and left-5 or right+5
                d.healthBar.bg.From=Vector2.new(barX,top) d.healthBar.bg.To=Vector2.new(barX,bottom)
                d.healthBar.bar.From=Vector2.new(barX,bottom) d.healthBar.bar.To=Vector2.new(barX,bottom-barH)
                d.healthBar.bg.Thickness=4 d.healthBar.bg.Color=Color3.new(0,0,0) d.healthBar.bg.Transparency=1 d.healthBar.bg.Visible=true
                d.healthBar.bar.Thickness=2 d.healthBar.bar.Color=Color3.fromHSV(ratio*120/360,1,1) d.healthBar.bar.Transparency=1 d.healthBar.bar.Visible=true
            else d.healthBar.bg.Visible=false d.healthBar.bar.Visible=false end
            if armorBarEnabled and enabled then
                local armorVal=0
                local be2=char:FindFirstChild('BodyEffects')
                if be2 then local a=be2:FindFirstChild('Armor') if a then armorVal=a.Value end end
                local ratio=math.clamp(armorVal/100,0,1)
                local barX = right+5+(healthBarSide=='Right' and 5 or 0)
                d.armorBar.bg.From=Vector2.new(barX,top) d.armorBar.bg.To=Vector2.new(barX,bottom)
                d.armorBar.bar.From=Vector2.new(barX,bottom) d.armorBar.bar.To=Vector2.new(barX,bottom-height*ratio)
                d.armorBar.bg.Thickness=4 d.armorBar.bg.Color=Color3.new(0,0,0) d.armorBar.bg.Transparency=1 d.armorBar.bg.Visible=true
                d.armorBar.bar.Thickness=2 d.armorBar.bar.Color=armorBarColor d.armorBar.bar.Transparency=1 d.armorBar.bar.Visible=true
            else d.armorBar.bg.Visible=false d.armorBar.bar.Visible=false end
            if namesEnabled and enabled then
                d.name.Text=player.DisplayName..' (@'..player.Name..')'
                d.name.Color=namesColor d.name.Position=Vector2.new(sTop.X,top-16) d.name.Center=true d.name.Visible=true
            else d.name.Visible=false end
            if distanceEnabled and enabled then
                d.distance.Text=dist..' studs'
                d.distance.Color=distanceColor d.distance.Position=Vector2.new(sTop.X,bottom+2) d.distance.Center=true d.distance.Visible=true
            else d.distance.Visible=false end
            if toolEnabled and enabled then
                local tool=char:FindFirstChildOfClass('Tool')
                d.tool.Text=tool and tool.Name or ''
                d.tool.Color=toolColor d.tool.Position=Vector2.new(sTop.X,bottom+14) d.tool.Center=true d.tool.Visible=tool~=nil
            else d.tool.Visible=false end
            if tracersEnabled and enabled then
                local vpS=cam.ViewportSize
                local oy = tracerOrigin=='Bottom' and vpS.Y or tracerOrigin=='Center' and vpS.Y/2 or 0
                d.tracer.From=Vector2.new(vpS.X/2,oy) d.tracer.To=Vector2.new(sBot.X,sBot.Y)
                d.tracer.Color=tracerColor d.tracer.Transparency=1 d.tracer.Visible=true
            else d.tracer.Visible=false end
            if skeletonEnabled and enabled then
                for i,bone in ipairs(skeletonBones) do
                    local p0=char:FindFirstChild(bone[1]) local p1=char:FindFirstChild(bone[2])
                    if p0 and p1 then
                        local s0,on0=w2s(p0.Position) local s1,on1=w2s(p1.Position)
                        if on0 and on1 then
                            d.skeleton[i].From=s0 d.skeleton[i].To=s1
                            d.skeleton[i].Color=skeletonColor d.skeleton[i].Transparency=1 d.skeleton[i].Visible=true
                        else d.skeleton[i].Visible=false end
                    else d.skeleton[i].Visible=false end
                end
            else for _,l in ipairs(d.skeleton) do l.Visible=false end end
            updateHighlight(player,d)
            updateChams(player,d)
        end
        local function onPlayerAdded(player)
            if player==lp then return end
            createPlayerESP(player)
            player.CharacterAdded:Connect(function()
                if playerESP[player] then
                    for _,inst in ipairs(playerESP[player].chams) do if inst.Parent then inst:Destroy() end end
                    playerESP[player].chams={}
                    if playerESP[player].highlight and playerESP[player].highlight.Parent then
                        playerESP[player].highlight:Destroy() playerESP[player].highlight=nil
                    end
                end
            end)
            player.CharacterRemoving:Connect(function()
                if playerESP[player] then
                    for _,inst in ipairs(playerESP[player].chams) do if inst.Parent then inst:Destroy() end end
                    playerESP[player].chams={}
                end
            end)
        end
        for _,p in ipairs(Players:GetPlayers()) do onPlayerAdded(p) end
        Players.PlayerAdded:Connect(onPlayerAdded)
        Players.PlayerRemoving:Connect(function(p) removePlayerESP(p) end)
        RunService.RenderStepped:Connect(function()
            if not enabled then
                for _,d in pairs(playerESP) do
                    hideAll(d)
                    if d.highlight and d.highlight.Parent then d.highlight:Destroy() d.highlight=nil end
                    for _,inst in ipairs(d.chams) do if inst.Parent then inst:Destroy() end end
                    d.chams={}
                end
                return
            end
            for player,d in pairs(playerESP) do updatePlayer(player,d) end
        end)
