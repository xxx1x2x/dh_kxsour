        local function isFixedCenterReticle(obj)
            if not (obj:IsA("ImageLabel") or obj:IsA("Frame")) then return false end
            local sz = obj.AbsoluteSize
            if sz.X > 150 or sz.Y > 150 then return false end
            if sz.X < 2  or sz.Y < 2  then return false end
            local vp  = Camera.ViewportSize
            local abs = obj.AbsolutePosition
            local cx  = abs.X + sz.X / 2
            local cy  = abs.Y + sz.Y / 2
            local dx  = math.abs(cx - vp.X / 2)
            local dy  = math.abs(cy - vp.Y / 2)
            return dx < 80 and dy < 80
        end
        local function hideAll()
            local pg = LocalPlayer:FindFirstChild("PlayerGui")
            if not pg then return end
            for _, obj in ipairs(pg:GetDescendants()) do
                if isFixedCenterReticle(obj) and not hcHidden[obj] then
                    if obj:IsA("ImageLabel") then
                        hcHidden[obj]={Image=obj.Image,Visible=obj.Visible,ImageTransparency=obj.ImageTransparency}
                        obj.ImageTransparency=1 obj.Visible=false
                    else
                        hcHidden[obj]={Visible=obj.Visible,BackgroundTransparency=obj.BackgroundTransparency}
                        obj.BackgroundTransparency=1 obj.Visible=false
                    end
                end
            end
        end
        local function showAll()
