                            local sd   = be:FindFirstChild("SDeath") and be["SDeath"].Value
                            if not sd then
                                local dist = (tHRP.Position - RootPart.Position).Magnitude
                                local eff  = isKO and (dist+10000) or dist
                                if eff < closestDist then closestDist=eff lockedTarget=plr end
                            end
                        end
                    end
                end
            end
        end
        if not lockedTarget or not lockedTarget.Character then
            if lockedTarget and not lockedTarget:IsDescendantOf(game) then
                _G.rb_lockedTargetUserId=nil lockedTarget=nil _G.rb_shouldSwitch=true
            end
            messageLabel.Text="no target... (void)"
            _G.rb_isInCombat=false _G.rb_voiding=true _G.rb_teleporting=false
            reloadTool()
            workspace.CurrentCamera.CameraSubject=Character:FindFirstChild("Humanoid")
            return
        end
        if lockedTarget then _G.rb_lockedTargetUserId = lockedTarget.UserId end
        local TargetChar = lockedTarget.Character
        if not TargetChar then
            messageLabel.Text="killing (no stream): "..lockedTarget.Name
            _G.rb_isInCombat=true _G.rb_voiding=false _G.rb_teleporting=true
            if _G.rb_lockedTargetUserId then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr.UserId==_G.rb_lockedTargetUserId and plr.Character then lockedTarget=plr break end
                end
            end
            return
        end
        local TargetRoot  = TargetChar:FindFirstChild("HumanoidRootPart")
        local UpperTorso  = TargetChar:FindFirstChild("UpperTorso")
        local TargetBE    = TargetChar:FindFirstChild("BodyEffects")
        local TargetHum   = TargetChar:FindFirstChild("Humanoid")
        local TargetFF    = TargetChar:FindFirstChildOfClass("ForceField")
        if TargetRoot then _G.rb_lastKnownTargetPos = TargetRoot.Position end
        if not TargetRoot or not TargetHum or TargetHum.Health<=0 then _G.rb_shouldSwitch=true _G.rb_isInCombat=false return end
        local isKO = TargetBE and TargetBE:FindFirstChild("K.O")    and TargetBE["K.O"].Value
        local isSD = TargetBE and TargetBE:FindFirstChild("SDeath") and TargetBE["SDeath"].Value
        if isKO and ragebotNotificationsEnabled and lastKilledTarget~=lockedTarget.UserId then
            killCount=killCount+1 lastKilledTarget=lockedTarget.UserId
            Library:Notify(string.format("✦ KILL  %s  [%d / %d]", lockedTarget.Name, killCount, deathCount), 4)
        end
        if isSD then
            messageLabel.Text="target dead... (switching)"
            _G.rb_isInCombat=false _G.rb_shouldSwitch=true lockedTarget=nil
            _G.rb_smoothedTargetPos=nil _G.rb_voiding=true _G.rb_teleporting=false reloadTool()
            return
        end
        if TargetFF then
            messageLabel.Text="waiting FF... (void)"
            _G.rb_isInCombat=false _G.rb_voiding=true _G.rb_teleporting=false reloadTool()
            if ragebotviewactive then workspace.CurrentCamera.CameraSubject=UpperTorso or TargetHum
            else workspace.CurrentCamera.CameraSubject=Character:FindFirstChild("Humanoid") end
            return
        end
        _G.rb_isInCombat=true _G.rb_voiding=false _G.rb_teleporting=true
        if ragebotviewactive then workspace.CurrentCamera.CameraSubject=UpperTorso or TargetHum
        else workspace.CurrentCamera.CameraSubject=Character:FindFirstChild("Humanoid") end
        if isKO and UpperTorso and ragebotstompactive and _G.rb_canrun then
            messageLabel.Text="stomping: "..lockedTarget.Name
            _G.rb_teleporting=false _G.rb_voiding=false
            RootPart.Velocity=Vector3.zero RootPart.RotVelocity=Vector3.zero
            RootPart.AssemblyLinearVelocity=Vector3.zero RootPart.AssemblyAngularVelocity=Vector3.zero
            RootPart.CFrame=CFrame.new(UpperTorso.Position+Vector3.new(0,3.5,0))
            task.wait(0.1) MainEvent:FireServer("Stomp")
            
            _G.rb_voiding=true _G.rb_teleporting=false
            messageLabel.Text="waiting FF after stomp... (void)"
            task.spawn(function()
                local maxWait = 30
                local elapsed = 0
                while elapsed < maxWait do
                    task.wait(0.3)
                    elapsed = elapsed + 0.3
                    if not lockedTarget then break end
                    local tC = lockedTarget.Character
                    if not tC then
                        _G.rb_shouldSwitch=true _G.rb_voiding=true _G.rb_teleporting=false
                        break
                    end
                    local tBE2 = tC:FindFirstChild("BodyEffects")
                    local isSD2 = tBE2 and tBE2:FindFirstChild("SDeath") and tBE2["SDeath"].Value
                    if isSD2 then
                        _G.rb_shouldSwitch=true _G.rb_voiding=true _G.rb_teleporting=false
                        break
                    end
                    local ff = tC:FindFirstChildOfClass("ForceField")
                    if not ff then
                        _G.rb_voiding=false _G.rb_teleporting=true
                        break
                    end
                end
            end)
            return
        end
        if not isKO and _G.rb_canrun then
            messageLabel.Text="killing: "..lockedTarget.Name
            local tPos = TargetRoot.Position
            if not flamethrower_hack then _G.rb_smoothedTargetPos=nil end
            if ragebotrandomtpactive then
                if ragebotrandomrotationactive then
                    RootPart.CFrame=CFrame.new(tPos+Vector3.new(math.random(-20,20),math.random(-20,20),math.random(-20,20)))
                        *CFrame.Angles(math.rad(math.random(0,360)),math.rad(math.random(0,360)),math.rad(math.random(0,360)))
                else
                    RootPart.CFrame=CFrame.lookAt(tPos+Vector3.new(math.random(-20,20),math.random(-20,20),math.random(-20,20)),tPos)
                end
            else
                RootPart.CFrame=CFrame.lookAt(tPos+Vector3.new(math.random(-20,20),math.random(-20,20),math.random(-20,20)),tPos)
            end
        end
    end)

    task.spawn(function()
        while true do
            if ragebotactive and AbuseProtection then
                local char = LocalPlayer.Character
                if char then
                    local ff  = char:FindFirstChildOfClass("ForceField")
                    local be  = char:FindFirstChild("BodyEffects")
                    local isKO= be and be:FindFirstChild("K.O") and be["K.O"].Value
                    local isReloading = be and be:FindFirstChild("Reload") and be.Reload.Value
                    if not ff and not isKO and not isReloading then
                        local hum = char:FindFirstChild("Humanoid")
                        if hum and hum.Health > 0 then
                            _G.rb_canrun=false _G.rb_voiding=true _G.rb_teleporting=false
                            task.wait(0.1) hum.Health=0 task.wait(0.1) _G.rb_canrun=true
                        end
                    end
                end
            end
            task.wait()
        end
    end)

    local function resetRagebot()
        ragebotactive=false lockedTarget=nil _G.rb_shouldSwitch=false _G.rb_isInCombat=false
        _G.rb_voiding=false _G.rb_teleporting=false messageLabel.Text=""
        workspace.CurrentCamera.CameraSubject=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        local char = LocalPlayer.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                if _G.rb_originalPosition then hrp.CFrame=_G.rb_originalPosition end
                hrp.Anchored=false hrp.AssemblyLinearVelocity=Vector3.new(0,0,0) hrp.AssemblyAngularVelocity=Vector3.new(0,0,0)
            end
            local animate=char:FindFirstChild("Animate") if animate then animate.Disabled=false end
            local hum=char:FindFirstChild("Humanoid") if hum then hum.AutoRotate=true end
        end
        _G.rb_originalPosition=nil
        if ragebotNotificationsEnabled then killCount=0 deathCount=0 lastKilledTarget=nil end
    end

    Toggles.ragebotenabled:OnChanged(function()
        ragebotenabled=Toggles.ragebotenabled.Value
        if not ragebotenabled then resetRagebot() end
    end)
    Options.ragebotkeybind:OnClick(function()
        if not ragebotenabled or UserInputService:GetFocusedTextBox() then return end
        ragebotactive=not ragebotactive
        if ragebotactive then
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                _G.rb_originalPosition=LocalPlayer.Character.HumanoidRootPart.CFrame
            end
            _G.rb_shouldSwitch=true
        else resetRagebot() end
    end)
end



