    local function GetNearestPlayerSilent()
        local Distance = math.huge
        local Target = nil
        local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        for _, plr in pairs(Players:GetPlayers()) do
            if plr == LocalPlayer or not plr.Character or not plr.Character:FindFirstChild(SilentAimSettings.TargetPart) then continue end
            local be = plr.Character:FindFirstChild("BodyEffects")
            local ko = be and be:FindFirstChild("K.O") and be["K.O"].Value
            if SilentAimSettings.KOCheck and ko then continue end
            local Position, OnScreen = Camera:WorldToViewportPoint(plr.Character:FindFirstChild(SilentAimSettings.TargetPart).Position)
            local Magnitude = (Vector2.new(Position.X, Position.Y) - screenCenter).Magnitude
            if OnScreen and Magnitude <= SilentAimSettings.FOV and Magnitude <= Distance then
                Distance = Magnitude
                Target = plr.Character:FindFirstChild(SilentAimSettings.TargetPart)
            end
        end
        return Target
    end

