do
    local function GetClosestPlayer()
        local closestPlayer = nil
        local shortestDistance = AimbotSettings.FOV
        local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local targetPart = plr.Character:FindFirstChild(AimbotSettings.TargetPart)
                local hum = plr.Character:FindFirstChild("Humanoid")
                if targetPart and hum and hum.Health > 0 then
                    local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen then
                        local dist = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
                        if dist < shortestDistance then closestPlayer = plr shortestDistance = dist end
                    end
                end
            end
        end
        return closestPlayer
    end

    RunService.RenderStepped:Connect(function()
        local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        FOVCircle.Position = screenCenter
        FOVCircle.Radius = AimbotSettings.FOV
        FOVCircle.Color = AimbotSettings.FOVColor
        FOVCircle.Visible = AimbotSettings.ShowFOV
        if CharacterSettings.FlyEnabled and LocalPlayer.Character then
            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local md = Vector3.new(0,0,0)
                local spd = CharacterSettings.FlySpeed
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then md = md + Camera.CFrame.LookVector * spd end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then md = md - Camera.CFrame.LookVector * spd end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then md = md - Camera.CFrame.RightVector * spd end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then md = md + Camera.CFrame.RightVector * spd end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then md = md + Vector3.new(0,spd,0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then md = md - Vector3.new(0,spd,0) end
                hrp.Velocity = md
            end
        end
        local shouldAim = AimbotSettings.Enabled and Options.AimbotKey and Options.AimbotKey:GetState()
        if shouldAim then
            local target
            if AimbotSettings.Sticky and AimbotSettings.StickyTarget then
                local sc = AimbotSettings.StickyTarget
                if sc.Character and sc.Character:FindFirstChild("Humanoid") and sc.Character.Humanoid.Health > 0 then
                    target = sc
                else
                    AimbotSettings.StickyTarget = nil
                end
            end
            if not target then
                target = GetClosestPlayer()
                if AimbotSettings.Sticky and target then AimbotSettings.StickyTarget = target end
            end
            if target and target.Character then
                local tp = target.Character:FindFirstChild(AimbotSettings.TargetPart)
                if tp then
                    Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, tp.Position), AimbotSettings.Smoothness)
                end
            end
        else
            AimbotSettings.StickyTarget = nil
        end
        if MiscSettings.AntiStompEnabled and LocalPlayer.Character then
            local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
            local be  = LocalPlayer.Character:FindFirstChild("BodyEffects")
            local ko  = be and be:FindFirstChild("K.O")
            if hum and ko and ko.Value then
                if respawnEnabled then
                    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then lastDeathPos = hrp.CFrame end
                end
                hum.Health = 0
            end
            if hum and hum.Health <= 1 then
                if respawnEnabled then
                    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then lastDeathPos = hrp.CFrame end
                end
                hum.Health = 0
            end
        end
        if MiscSettings.AntiSlowEnabled and LocalPlayer.Character then
            local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then
                for _, eff in pairs(hum:GetChildren()) do
                    if eff:IsA("NumberValue") and eff.Name == "Slowed" then eff:Destroy() end
                end
                if hum.WalkSpeed < 16 and not CharacterSettings.SpeedEnabled then hum.WalkSpeed = 16 end
            end
        end
        if MiscSettings.NoClipEnabled and LocalPlayer.Character then
            for _, part in pairs(LocalPlayer.Character:GetChildren()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)

    
    local HitboxSettings = {
        Enabled = false,
        Size = 10,
        Transparency = 0.5
    }
    local OriginalHeadSizes = {}

    local function applyHitbox(player)
        if not player.Character then return end
        local head = player.Character:FindFirstChild("Head")
        if head and not OriginalHeadSizes[player.UserId] then
            OriginalHeadSizes[player.UserId] = head.Size
        end
        if head and HitboxSettings.Enabled then
            head.Size = Vector3.new(HitboxSettings.Size, HitboxSettings.Size, HitboxSettings.Size)
            head.Transparency = HitboxSettings.Transparency
            head.CanCollide = false
            head.Massless = true
        end
    end

    local function resetHitbox(player)
        if not player.Character then return end
        local head = player.Character:FindFirstChild("Head")
        if head and OriginalHeadSizes[player.UserId] then
            head.Size = OriginalHeadSizes[player.UserId]
            head.Transparency = 0
            head.CanCollide = true
            head.Massless = false
        end
        OriginalHeadSizes[player.UserId] = nil
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            player.CharacterAdded:Connect(function()
                OriginalHeadSizes[player.UserId] = nil
                task.wait(0.1)
                if HitboxSettings.Enabled then
                    applyHitbox(player)
                end
            end)
        end
    end

    Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function()
            OriginalHeadSizes[player.UserId] = nil
            task.wait(0.1)
            if HitboxSettings.Enabled then
                applyHitbox(player)
            end
        end)
    end)

    Players.PlayerRemoving:Connect(function(player)
        OriginalHeadSizes[player.UserId] = nil
    end)

    RunService.Heartbeat:Connect(function()
        if HitboxSettings.Enabled then
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local head = player.Character:FindFirstChild("Head")
                    if head then
                        head.Size = Vector3.new(HitboxSettings.Size, HitboxSettings.Size, HitboxSettings.Size)
                        head.Transparency = HitboxSettings.Transparency
                        head.CanCollide = false
                        head.Massless = true
                    end
                end
            end
        end
    end)

    local HitboxGroup = Tabs.Aimbot:AddLeftGroupbox('Hitbox Expander')
    HitboxGroup:AddToggle('EnableHitbox', {Text='Enable Hitbox', Default=false})
    HitboxGroup:AddSlider('HitboxSize', {Text='Size', Default=10, Min=1, Max=20, Rounding=0, Compact=false})
    HitboxGroup:AddSlider('HitboxTransparency', {Text='Transparency', Default=0.5, Min=0, Max=1, Rounding=2, Compact=false})

    Toggles.EnableHitbox:OnChanged(function()
        HitboxSettings.Enabled = Toggles.EnableHitbox.Value
        if HitboxSettings.Enabled then
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then applyHitbox(player) end
            end
        else
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then resetHitbox(player) end
            end
        end
    end)
    Options.HitboxSize:OnChanged(function() HitboxSettings.Size = Options.HitboxSize.Value end)
    Options.HitboxTransparency:OnChanged(function() HitboxSettings.Transparency = Options.HitboxTransparency.Value end)

    local AimbotGroup = Tabs.Aimbot:AddLeftGroupbox('Aimbot Settings')
