    dmgRayParams.IgnoreWater = true
    local function isVisible(player)
        if not player.Character or not player.Character:FindFirstChild("Head") then return false end
        local head = player.Character.Head
        local orig = Camera.CFrame.Position
        local dir  = (head.Position - orig)
        dmgRayParams.FilterDescendantsInstances = {LocalPlayer.Character}
        local res = workspace:Raycast(orig, dir, dmgRayParams)
        return not res or res.Instance:IsDescendantOf(player.Character)
    end
    local function getNearestCursor()
        local mouse = UserInputService:GetMouseLocation()
        local nearest, shortest = nil, math.huge
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") and isVisible(player) then
                local sp, on = Camera:WorldToViewportPoint(player.Character.Head.Position)
                if on then
                    local d = (Vector2.new(sp.X,sp.Y) - mouse).Magnitude
                    if d < shortest then shortest=d nearest=player end
                end
            end
        end
        return nearest
    end
